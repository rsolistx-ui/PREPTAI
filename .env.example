# PREPT AI — Required Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ── Anthropic (Claude AI) ─────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get from: https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # service_role key (NOT anon key — has full DB access)

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...          # use sk_test_... for local dev
STRIPE_WEBHOOK_SECRET=whsec_...       # from Stripe Dashboard → Webhooks → signing secret
STRIPE_CAREER_PRICE_ID=price_...      # Career+ monthly price ID from Stripe Products

# ── Resend (transactional email) ──────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# ── Supabase tables required ──────────────────────────────────────────────────
# usage         — columns: id (uuid), email (text), type (text), created_at (timestamptz)
# subscribers   — columns: id (uuid), email (text), plan (text: free|pro|career), created_at (timestamptz)
# user_sessions — columns: id (uuid), email (text), session_data (jsonb), created_at (timestamptz)
#
# RLS policies required on each table:
#   usage, subscribers: service_role bypass only (app accesses via service key)
#   user_sessions: same
